# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# Get this from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Comma-separated Telegram user IDs that get admin access
# You can find your ID by messaging @userinfobot
ADMIN_IDS=123456789,987654321

# Path where the SQLite database will be stored
# (automatically set to /data/bot.db when using Docker)
DB_PATH=data/bot.db

# Timezone for the cron scheduler (any pytz/IANA timezone string)
# Default: UTC
# Examples: America/New_York, Europe/London, Asia/Tokyo
SCHEDULER_TIMEZONE=UTC

# Logging level: DEBUG, INFO, WARNING, ERROR
# Default: INFO
LOG_LEVEL=INFO

# Whether to discard updates that arrived while the bot was offline
# Default: true
DROP_PENDING_UPDATES=true
